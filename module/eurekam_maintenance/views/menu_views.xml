    <menuitem id="menu_root_maintenance"
              name="Maintenance"
              sequence="55"
              groups="group_maintenance_user"/>

    <!-- Sous-menu "Contrats" -->
    <menuitem id="menu_maintenance_contracts"
              name="Contrats"
              parent="menu_root_maintenance"
              action="action_maintenance_contract"
              sequence="10"/>

    <!-- Sous-menu "Lignes annuelles" : vue transversale par année -->
