<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================== -->
    <!-- Vue formulaire                                                  -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_form" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.form</field>
        <field name="model">eurekam.maintenance.contract</field>
        <field name="arch" type="xml">
            <form string="Contrat de maintenance">
                <header>
                    <button name="action_activate" type="object"
                            string="Activer" class="oe_highlight"
                            invisible="state not in ('draft','cancelled')"/>
                    <button name="action_generate_lines" type="object"
                            string="Générer les lignes annuelles"
                            invisible="not date_start or not date_end"/>
                    <button name="action_open_renewal_wizard" type="object"
                            string="Renouveler" class="btn-primary"
                            invisible="state in ('draft','renewed','cancelled')"/>
                    <button name="action_open_create_order_wizard" type="object"
                            string="Créer une commande client" class="btn-primary"
                            invisible="state not in ('active','expiring') or not requires_customer_order"
                            help="Cas majoritaire : à réception d'un Bon de Commande client, crée un sale.order avec N lignes selon la cadence (1 pour Annuelle, 2 pour Semestrielle, 4 pour Trimestrielle). Chaque ligne du SO sera facturable indépendamment."/>
                    <button name="action_create_invoices_for_contract" type="object"
                            string="Créer les factures du contrat"
                            invisible="state not in ('active','expiring') or requires_customer_order"
                            help="Cas rare : facturation directe sans Bon de Commande (établissements privés). Génère les factures brouillon couvrant la durée restante du contrat selon la cadence."/>
                    <button name="action_recompute_state" type="object"
                            string="Recalculer l'état"
                            invisible="state in ('draft','cancelled','renewed')"
                            help="Re-évalue l'état (Actif / Expire bientôt / Expiré) selon la date de fin et la date du jour. Utile si le cron quotidien n'a pas tourné (cas sandbox / staging)."/>
                    <button name="action_cancel" type="object"
                            string="Annuler"
                            invisible="state in ('cancelled','renewed')"/>
                    <button name="action_draft" type="object"
                            string="Remettre en brouillon"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,expiring,expired,renewed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_lines" type="object"
                                class="oe_stat_button" icon="fa-calendar">
                            <field name="line_count" widget="statinfo"
                                   string="Lignes annuelles"/>
                        </button>
                        <button name="action_view_renewed_from" type="object"
                                class="oe_stat_button" icon="fa-history"
                                invisible="not renewed_from_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Renouvelé depuis</span>
                            </div>
                        </button>
                        <button name="action_view_renewed_to" type="object"
                                class="oe_stat_button" icon="fa-arrow-right"
                                invisible="renewed_to_count == 0">
                            <field name="renewed_to_count" widget="statinfo"
                                   string="Renouvelé vers"/>
                        </button>
                        <button name="action_view_sale_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="sale_order_count == 0">
                            <field name="sale_order_count" widget="statinfo"
                                   string="Commandes"/>
                        </button>
                        <button name="action_view_invoices" type="object"
                                class="oe_stat_button" icon="fa-money"
                                invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo"
                                   string="Factures"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="sequence_number" class="oe_edit_only"/>
                        <h1>
                            <field name="sequence_number" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="partner_id"/>
                            <field name="product_id"/>
                            <field name="product_name"/>
                            <field name="commercial_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="country_id"/>
                        </group>
                        <group string="Caractéristiques">
                            <field name="gen"/>
                            <field name="market_type"/>
                            <field name="order_status"/>
                            <field name="nb_products"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dates et durée" name="dates">
                            <group>
                                <group>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="duration"/>
                                </group>
                                <group>
                                    <field name="days_to_expiry"/>
                                    <field name="is_expiring_soon"/>
                                </group>
                            </group>
                        </page>
                        <page string="Facturation" name="billing">
                            <group>
                                <group string="Conditions">
                                    <field name="maintenance_amount"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="billing_level"/>
                                    <field name="syntec_revision"/>
                                    <field name="requires_customer_order"/>
                                </group>
                                <group string="Totaux (calculés)">
                                    <field name="total_contract_value"/>
                                    <field name="current_year_amount"/>
                                </group>
                            </group>
                            <group>
                                <group string="Cadences de facturation">
                                    <field name="billing_frequency_ids"
                                           widget="many2many_tags"
                                           options="{'color_field': 'color'}"
                                           nolabel="1"/>
                                </group>
                                <group string="Facturation modules">
                                    <field name="module_billing_ids"
                                           widget="many2many_tags"
                                           options="{'color_field': 'color'}"
                                           nolabel="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Montants annuels" name="annual_lines">
                            <p class="text-muted">
                                Saisissez le montant annuel pour chaque année du contrat.
                                Le bouton « Générer les lignes annuelles » dans l'en-tête
                                pré-crée une ligne pour chaque année entre la date de
                                début et la date de fin.
                            </p>
                            <field name="line_ids">
                                <list editable="bottom"
                                      decoration-success="is_invoiced">
                                    <field name="year"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="currency_id" column_invisible="True"/>
                                    <field name="invoice_count" optional="show"/>
                                    <field name="is_invoiced" widget="boolean_toggle" readonly="1"/>
                                    <field name="invoice_ids" widget="many2many_tags" optional="show"/>
                                    <field name="notes" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="comment" placeholder="Commentaires libres..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue liste                                                       -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_list" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.list</field>
        <field name="model">eurekam.maintenance.contract</field>
        <field name="arch" type="xml">
            <list string="Contrats de maintenance"
                  decoration-warning="is_expiring_soon"
                  decoration-danger="state == 'expired'"
                  decoration-muted="state in ('cancelled','renewed')">
                <field name="sequence_number"/>
                <field name="partner_id"/>
                <field name="product_id" optional="show"/>
                <field name="gen" optional="show"/>
                <field name="market_type" optional="show"/>
                <field name="order_status" optional="show"/>
                <field name="date_start" optional="hide"/>
                <field name="date_end"/>
                <field name="duration" optional="show"/>
                <field name="maintenance_amount" sum="Total"/>
                <field name="current_year_amount" optional="show" sum="Total année courante"/>
                <field name="total_contract_value" optional="hide" sum="Total contrats"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="syntec_revision" optional="hide"/>
                <field name="commercial_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'expiring'"
                       decoration-danger="state == 'expired'"
                       decoration-info="state == 'draft'"
                       decoration-muted="state in ('cancelled','renewed')"/>
                <field name="is_expiring_soon" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue kanban                                                      -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_kanban" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.kanban</field>
        <field name="model">eurekam.maintenance.contract</field>
        <field name="arch" type="xml">
            <kanban default_group_by="order_status" class="o_kanban_small_column">
                <field name="state"/>
                <field name="is_expiring_soon"/>
                <field name="color"/>
                <field name="currency_id"/>
                <field name="current_year_amount"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title">
                                        <field name="partner_id"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div><field name="product_id"/></div>
                                    <div>
                                        <strong>Année courante :</strong>
                                        <field name="current_year_amount" widget="monetary"/>
                                    </div>
                                    <div t-if="record.date_end.raw_value">
                                        Fin : <field name="date_end"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'active': 'success', 'expiring': 'warning', 'expired': 'danger', 'draft': 'default'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue recherche                                                   -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_search" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.search</field>
        <field name="model">eurekam.maintenance.contract</field>
        <field name="arch" type="xml">
            <search string="Rechercher des contrats">
                <field name="sequence_number"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="commercial_id"/>
                <separator/>
                <filter string="Brouillon" name="filter_draft"
                        domain="[('state','=','draft')]"/>
                <filter string="Actifs" name="filter_active"
                        domain="[('state','=','active')]"/>
                <filter string="Expirent bientôt" name="filter_expiring_soon"
                        domain="[('is_expiring_soon','=',True)]"/>
                <filter string="Expirés" name="filter_expired"
                        domain="[('state','=','expired')]"/>
                <separator/>
                <filter string="Mes contrats" name="filter_my_contracts"
                        domain="[('commercial_id','=',uid)]"/>
                <separator/>
                <filter string="Avec révision Syntec" name="filter_syntec_yes"
                        domain="[('syntec_revision','=','yes')]"/>
                <group expand="0" string="Grouper par">
                    <filter string="État" name="group_state"
                            context="{'group_by':'state'}"/>
                    <filter string="Statut commande" name="group_status"
                            context="{'group_by':'order_status'}"/>
                    <filter string="Génération" name="group_gen"
                            context="{'group_by':'gen'}"/>
                    <filter string="Marché" name="group_market"
                            context="{'group_by':'market_type'}"/>
                    <filter string="Établissement" name="group_partner"
                            context="{'group_by':'partner_id'}"/>
                    <filter string="Commercial" name="group_commercial"
                            context="{'group_by':'commercial_id'}"/>
                    <filter string="Révision Syntec" name="group_syntec"
                            context="{'group_by':'syntec_revision'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue pivot                                                       -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_pivot" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.pivot</field>
        <field name="model">eurekam.maintenance.contract</field>
        <field name="arch" type="xml">
            <pivot string="Analyse des contrats" sample="1">
                <field name="partner_id" type="row"/>
                <field name="gen" type="col"/>
                <field name="maintenance_amount" type="measure"/>
                <field name="total_contract_value" type="measure"/>
                <!-- current_year_amount n'est pas une mesure car le champ
                     est computed non-stocke (store=False) : impossible a
                     agreger en SQL. Pour analyser l'annee courante, utiliser
                     le pivot du menu "Lignes annuelles" filtre sur l'annee. -->
            </pivot>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue graph                                                       -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_graph" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.graph</field>
        <field name="model">eurekam.maintenance.contract</field>
        <field name="arch" type="xml">
            <graph string="Contrats par marché" type="bar" sample="1">
                <field name="market_type"/>
                <field name="maintenance_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue calendrier                                                  -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_calendar" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.calendar</field>
        <field name="model">eurekam.maintenance.contract</field>
        <field name="arch" type="xml">
            <calendar string="Contrats"
                      date_start="date_start"
                      date_stop="date_end"
                      color="commercial_id"
                      mode="month">
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Action principale (avec toutes les vues disponibles)            -->
    <!-- ============================================================== -->
    <record id="action_maintenance_contract" model="ir.actions.act_window">
        <field name="name">Contrats de maintenance</field>
        <field name="res_model">eurekam.maintenance.contract</field>
        <field name="view_mode">list,kanban,form,pivot,graph,calendar</field>
        <field name="search_view_id" ref="view_maintenance_contract_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre premier contrat de maintenance
            </p>
            <p>
                Suivez le cycle de vie complet de vos contrats Drugcam :
                facturation, renouvellement, alertes d'expiration.
            </p>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Action "Tableau de bord" : ouvre directement pivot/graph        -->
    <!-- ============================================================== -->
    <record id="action_maintenance_dashboard" model="ir.actions.act_window">
        <field name="name">Tableau de bord</field>
        <field name="res_model">eurekam.maintenance.contract</field>
        <field name="view_mode">pivot,graph</field>
        <field name="search_view_id" ref="view_maintenance_contract_search"/>
        <field name="context">{
            'pivot_measures': ['maintenance_amount', 'total_contract_value'],
            'pivot_row_groupby': ['partner_id'],
            'pivot_column_groupby': ['gen'],
            'graph_measure': 'maintenance_amount',
            'graph_groupbys': ['market_type'],
        }</field>
    </record>

</odoo>
