        <field name="arch" type="xml">
            <list string="Versions produit" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_product_version" model="ir.actions.act_window">
        <field name="name">Versions produit Drugcam</field>
        <field name="res_model">eurekam.product.version</field>
        <field name="view_mode">list</field>
    </record>

