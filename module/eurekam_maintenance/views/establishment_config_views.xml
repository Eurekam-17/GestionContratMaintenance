<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Note (refactor option A) :
        Les vues pour eurekam.establishment.type et eurekam.product.version
        ont ete supprimees. Les types d'etablissement et versions produit
        utilisent maintenant les tags standard res.partner.category
        (deja accessibles via Contacts > Configuration > Contact Tags).
    -->

    <!-- =========== eurekam.module.status =========== -->
    <record id="view_module_status_list" model="ir.ui.view">
        <field name="name">eurekam.module.status.list</field>
        <field name="model">eurekam.module.status</field>
        <field name="arch" type="xml">
            <list string="Statuts module" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_module_status" model="ir.actions.act_window">
        <field name="name">Statuts module</field>
        <field name="res_model">eurekam.module.status</field>
        <field name="view_mode">list</field>
    </record>

    <!-- =========== eurekam.special.equipment =========== -->
    <record id="view_special_equipment_list" model="ir.ui.view">
        <field name="name">eurekam.special.equipment.list</field>
        <field name="model">eurekam.special.equipment</field>
        <field name="arch" type="xml">
            <list string="Équipements spéciaux" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_special_equipment" model="ir.actions.act_window">
        <field name="name">Équipements spéciaux</field>
        <field name="res_model">eurekam.special.equipment</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
