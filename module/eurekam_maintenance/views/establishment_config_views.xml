<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================== -->
    <!-- Vue generique reutilisable pour les 4 modeles auxiliaires       -->
    <!-- (name, code, sequence, color, active)                           -->
    <!-- ============================================================== -->

    <!-- =========== eurekam.establishment.type =========== -->
    <record id="view_establishment_type_list" model="ir.ui.view">
        <field name="name">eurekam.establishment.type.list</field>
        <field name="model">eurekam.establishment.type</field>
        <field name="arch" type="xml">
            <list string="Types d'établissement" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_establishment_type" model="ir.actions.act_window">
        <field name="name">Types d'établissement</field>
        <field name="res_model">eurekam.establishment.type</field>
        <field name="view_mode">list</field>
    </record>

    <!-- =========== eurekam.product.version =========== -->
