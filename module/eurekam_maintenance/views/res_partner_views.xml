<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================== -->
    <!-- Extension de la vue formulaire res.partner                      -->
    <!-- Ajoute un onglet "Maintenance Eurekam" + un smart button.        -->
    <!-- ============================================================== -->
    <record id="view_res_partner_form_maintenance" model="ir.ui.view">
        <field name="name">res.partner.form.maintenance</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Smart button : compteur de contrats de maintenance.
                 Le champ is_maintenance_establishment doit etre declare invisible
                 ICI pour etre pre-fetche cote client (utilise dans plusieurs
                 expressions 'invisible' qui sont evaluees AVANT le bloc group
                 ou le champ visible est declare). -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="is_maintenance_establishment" invisible="1"/>
                <field name="maintenance_status" invisible="1"/>
                <field name="active_maintenance_contract_count" invisible="1"/>
                <field name="expiring_maintenance_contract_count" invisible="1"/>
                <field name="expired_maintenance_contract_count" invisible="1"/>
                <button name="action_view_maintenance_contracts" type="object"
                        class="oe_stat_button" icon="fa-wrench"
                        invisible="not is_maintenance_establishment">
                    <field name="maintenance_contract_count" widget="statinfo"
                           string="Contrats"/>
                </button>
            </xpath>

            <!-- ALERTES MAINTENANCE : 4 bandeaux colores selon le statut, visibles
                 pour TOUTE l'equipe (notamment support) qui ouvre une fiche client.
                 Visible uniquement si is_maintenance_establishment pour ne pas
                 polluer les autres contacts (fournisseurs, employes, etc.). -->
            <xpath expr="//div[@name='button_box']" position="before">
                <div class="alert alert-success o_form_full_width mt-2 mb-3"
                     role="alert"
                     invisible="not is_maintenance_establishment or maintenance_status != 'active'">
                    <i class="fa fa-check-circle me-2"/>
                    <strong>Maintenance ACTIVE</strong>
                    <span class="ms-2">
                        (<field name="active_maintenance_contract_count" readonly="1" nolabel="1" class="oe_inline"/> contrat(s) actif(s))
                    </span>
                </div>
                <div class="alert alert-warning o_form_full_width mt-2 mb-3"
                     role="alert"
                     invisible="not is_maintenance_establishment or maintenance_status != 'expiring'">
                    <i class="fa fa-exclamation-triangle me-2"/>
                    <strong>Maintenance EXPIRE BIENTÔT</strong>
                    <span class="ms-2">
                        (<field name="expiring_maintenance_contract_count" readonly="1" nolabel="1" class="oe_inline"/> contrat(s) à renouveler)
                    </span>
                </div>
                <div class="alert alert-danger o_form_full_width mt-2 mb-3"
                     role="alert"
                     invisible="not is_maintenance_establishment or maintenance_status != 'expired'">
                    <i class="fa fa-times-circle me-2"/>
                    <strong>Maintenance EXPIRÉE</strong>
                    <span class="ms-2">
                        (<field name="expired_maintenance_contract_count" readonly="1" nolabel="1" class="oe_inline"/> contrat(s) expiré(s))
                    </span>
                </div>
                <div class="alert alert-secondary o_form_full_width mt-2 mb-3"
                     role="alert"
                     invisible="not is_maintenance_establishment or maintenance_status != 'none'">
                    <i class="fa fa-info-circle me-2"/>
                    <strong>Aucun contrat de maintenance</strong>
                    <span class="ms-2 text-muted">
                        — cet établissement n'a pas de contrat actif, expirant ou expiré actuellement.
                    </span>
                </div>
            </xpath>

            <!-- Marqueur dans le bandeau du formulaire (a cote du nom) -->
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_maintenance_establishment"/>
            </xpath>

            <!-- Onglet Maintenance Eurekam dans le notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Maintenance Eurekam" name="maintenance_eurekam"
                      invisible="not is_maintenance_establishment">
                    <group>
                        <group string="Localisation">
                            <field name="department_number"/>
                        </group>
                        <group string="Classification">
                            <!-- Type d'établissement (CH, CHU, CLCC...) : utiliser les tags
                                 standard Odoo (champ category_id) déjà affichés en haut
                                 de la fiche partenaire. -->
                            <field name="establishment_status"/>
                            <field name="central_purchasing"/>
                        </group>
                    </group>
                    <group>
                        <group string="Équipements installés">
                            <field name="nb_workstations"/>
                            <!-- Version produit (GEN1, GEN2) : utiliser les tags standard
                                 Odoo (champ category_id) déjà affichés en haut de la fiche. -->
                            <field name="module_status_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                            <field name="special_equipment_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </group>
                        <group string="Responsables Eurekam">
                            <field name="commercial_responsible_id"/>
                            <field name="adv_responsible_id"/>
                            <field name="active_maintenance_contract_count"
                                   readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Extension de la vue liste res.partner (decoration)              -->
    <!-- ============================================================== -->
    <record id="view_res_partner_list_maintenance" model="ir.ui.view">
        <field name="name">res.partner.list.maintenance</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='complete_name']" position="after">
                <field name="is_maintenance_establishment" optional="hide"/>
                <field name="department_number" optional="hide"/>
                <field name="maintenance_contract_count" optional="hide"/>
                <field name="maintenance_status" optional="show"
                       widget="badge"
                       decoration-success="maintenance_status == 'active'"
                       decoration-warning="maintenance_status == 'expiring'"
                       decoration-danger="maintenance_status == 'expired'"
                       decoration-muted="maintenance_status == 'none'"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Extension de la vue search res.partner                          -->
    <!-- ============================================================== -->
    <record id="view_res_partner_search_maintenance" model="ir.ui.view">
        <field name="name">res.partner.search.maintenance</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='name']" position="after">
                <field name="department_number"/>
            </xpath>
            <xpath expr="//search" position="inside">
                <separator/>
                <filter string="Établissements maintenance"
                        name="filter_maintenance_establishments"
                        domain="[('is_maintenance_establishment','=',True)]"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Action : liste filtree des etablissements de maintenance        -->
    <!-- ============================================================== -->
    <record id="action_maintenance_establishment" model="ir.actions.act_window">
        <field name="name">Établissements</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_maintenance_establishment', '=', True)]</field>
        <field name="context">
            {
                'default_is_maintenance_establishment': True,
                'default_is_company': True,
                'search_default_filter_maintenance_establishments': 1,
            }
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Référencez votre premier établissement client
            </p>
            <p>
                Les établissements de maintenance regroupent les hôpitaux, cliniques
                et distributeurs pour lesquels vous suivez des contrats Drugcam.
            </p>
        </field>
    </record>

</odoo>
