<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================== -->
    <!-- Vue liste des lignes annuelles (vue transversale)               -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_line_list" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.line.list</field>
        <field name="model">eurekam.maintenance.contract.line</field>
        <field name="arch" type="xml">
            <list string="Lignes annuelles"
                  decoration-success="is_invoiced"
                  decoration-muted="contract_state in ('cancelled','expired')"
                  editable="bottom">
                <field name="contract_id"/>
                <field name="partner_id"/>
                <field name="year"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="is_invoiced" widget="boolean_toggle"/>
                <field name="invoice_id" optional="show"/>
                <field name="commercial_id" optional="hide"/>
                <field name="contract_state" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue liste editable in-line dans le formulaire contrat           -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_line_inline_list" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.line.inline.list</field>
        <field name="model">eurekam.maintenance.contract.line</field>
        <field name="arch" type="xml">
            <list editable="bottom"
                  decoration-success="is_invoiced">
                <field name="year"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="is_invoiced" widget="boolean_toggle"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue formulaire ligne annuelle                                   -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_line_form" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.line.form</field>
        <field name="model">eurekam.maintenance.contract.line</field>
        <field name="arch" type="xml">
            <form string="Ligne annuelle">
                <sheet>
                    <group>
                        <group>
                            <field name="contract_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="year"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="is_invoiced" widget="boolean_toggle"/>
                            <field name="invoice_id" readonly="1"/>
                            <field name="contract_state" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue pivot (analyse par année / établissement)                   -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_line_pivot" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.line.pivot</field>
        <field name="model">eurekam.maintenance.contract.line</field>
        <field name="arch" type="xml">
            <pivot string="Analyse des montants annuels">
                <field name="year" type="col"/>
                <field name="partner_id" type="row"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue graph                                                       -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_line_graph" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.line.graph</field>
        <field name="model">eurekam.maintenance.contract.line</field>
        <field name="arch" type="xml">
            <graph string="Montants annuels" type="bar">
                <field name="year"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Vue recherche                                                   -->
    <!-- ============================================================== -->
    <record id="view_maintenance_contract_line_search" model="ir.ui.view">
        <field name="name">eurekam.maintenance.contract.line.search</field>
        <field name="model">eurekam.maintenance.contract.line</field>
        <field name="arch" type="xml">
            <search string="Rechercher">
                <field name="contract_id"/>
                <field name="partner_id"/>
                <field name="year"/>
                <separator/>
                <filter string="Facturées" name="filter_invoiced"
                        domain="[('is_invoiced','=',True)]"/>
                <filter string="Non facturées" name="filter_not_invoiced"
                        domain="[('is_invoiced','=',False)]"/>
                <separator/>
                <filter string="Année courante" name="filter_current_year"
                        domain="[('year','=', context_today().year)]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Année" name="group_year"
                            context="{'group_by':'year'}"/>
                    <filter string="Établissement" name="group_partner"
                            context="{'group_by':'partner_id'}"/>
                    <filter string="Contrat" name="group_contract"
                            context="{'group_by':'contract_id'}"/>
                    <filter string="État du contrat" name="group_contract_state"
                            context="{'group_by':'contract_state'}"/>
                    <filter string="Commercial" name="group_commercial"
                            context="{'group_by':'commercial_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Action                                                          -->
    <!-- ============================================================== -->
    <record id="action_maintenance_contract_line" model="ir.actions.act_window">
        <field name="name">Lignes annuelles</field>
        <field name="res_model">eurekam.maintenance.contract.line</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="search_view_id" ref="view_maintenance_contract_line_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune ligne annuelle pour l'instant
            </p>
            <p>
                Les lignes annuelles sont créées depuis un contrat de maintenance
                (bouton « Générer les lignes annuelles »).
            </p>
        </field>
    </record>

</odoo>
