<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Séquence pour les contrats de maintenance : MAINT/AAAA/NNNN -->
        <record id="seq_eurekam_maintenance_contract" model="ir.sequence">
            <field name="name">Contrat de maintenance Eurekam</field>
            <field name="code">eurekam.maintenance.contract</field>
            <field name="prefix">MAINT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
