<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Cron quotidien : bascule les contrats en 'expiring' (J-90) ou
            'expired' (J+0) selon date_end et envoie les emails associes.

            Code execute :
                model._cron_check_expiring_contracts()
        -->
        <record id="cron_check_expiring_contracts" model="ir.cron">
            <field name="name">Eurekam Maintenance : vérification contrats expirants</field>
            <field name="model_id" ref="model_eurekam_maintenance_contract"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_expiring_contracts()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
