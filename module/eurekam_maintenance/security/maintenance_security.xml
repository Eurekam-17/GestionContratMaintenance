<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Catégorie de module pour regrouper les groupes Maintenance -->
        <record id="module_category_maintenance" model="ir.module.category">
            <field name="name">Maintenance Eurekam</field>
            <field name="description">Suivi des contrats de maintenance Eurekam.</field>
            <field name="sequence">20</field>
        </record>

        <!-- Groupe utilisateur : voit/édite ses contrats -->
        <record id="group_maintenance_user" model="res.groups">
            <field name="name">Utilisateur</field>
            <field name="category_id" ref="module_category_maintenance"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Groupe manager : configuration + suppression + voit tout -->
        <record id="group_maintenance_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_maintenance"/>
            <field name="implied_ids" eval="[(4, ref('group_maintenance_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Record rule : isolation multi-société pour les utilisateurs standard -->
        <record id="rule_maintenance_contract_company" model="ir.rule">
            <field name="name">Contrats de maintenance : isolation par société</field>
            <field name="model_id" ref="model_eurekam_maintenance_contract"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
