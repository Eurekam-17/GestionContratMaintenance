<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Template QWeb du rapport "Recapitulatif contrat de maintenance".
         Utilise web.external_layout pour le bandeau societe automatique. -->
    <template id="report_maintenance_contract">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- En-tête : numéro + état -->
                        <div class="row">
                            <div class="col-9">
                                <h2>Contrat de maintenance</h2>
                                <h3 class="text-muted"><t t-out="doc.sequence_number"/></h3>
                            </div>
                            <div class="col-3 text-end">
                                <span t-attf-class="badge bg-{{ {'draft': 'secondary', 'active': 'success', 'expiring': 'warning', 'expired': 'danger', 'renewed': 'info', 'cancelled': 'dark'}.get(doc.state, 'secondary') }}"
                                      style="font-size: 14px; padding: 8px;">
                                    <t t-out="dict(doc._fields['state'].selection).get(doc.state, '')"/>
                                </span>
                            </div>
                        </div>

                        <!-- Bloc identité -->
                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Établissement :</strong><br/>
                                <t t-out="doc.partner_id.display_name"/><br/>
                                <span t-if="doc.partner_id.street" t-out="doc.partner_id.street"/><br t-if="doc.partner_id.street"/>
                                <span t-if="doc.partner_id.zip" t-out="doc.partner_id.zip"/>
                                <span t-if="doc.partner_id.city" t-out="' ' + (doc.partner_id.city or '')"/>
                            </div>
                            <div class="col-6">
                                <strong>Commercial :</strong> <t t-out="doc.commercial_id.name or '-'"/><br/>
                                <strong>Pays :</strong> <t t-out="doc.country_id.name or '-'"/><br/>
                                <strong>Établissement :</strong>
                                <t t-out="', '.join(doc.partner_id.establishment_type_ids.mapped('name')) or '-'"/>
                            </div>
                        </div>

                        <!-- Caractéristiques produit -->
                        <h4 class="mt-4">Caractéristiques</h4>
                        <table class="table table-sm">
                            <tr>
                                <th style="width: 30%;">Produit</th>
                                <td><t t-out="doc.product_id.name or doc.product_name or '-'"/></td>
                            </tr>
                            <tr>
                                <th>Génération</th>
                                <td><t t-out="dict(doc._fields['gen'].selection).get(doc.gen, '-')"/></td>
                            </tr>
                            <tr>
                                <th>Marché</th>
                                <td><t t-out="dict(doc._fields['market_type'].selection).get(doc.market_type, '-')"/></td>
                            </tr>
                            <tr>
                                <th>Statut commande</th>
                                <td><t t-out="dict(doc._fields['order_status'].selection).get(doc.order_status, '-')"/></td>
                            </tr>
                            <tr>
                                <th>Nombre de produits</th>
                                <td><t t-out="doc.nb_products"/></td>
                            </tr>
                        </table>

                        <!-- Période -->
                        <h4 class="mt-4">Période et durée</h4>
                        <table class="table table-sm">
                            <tr>
                                <th style="width: 30%;">Date de début</th>
                                <td><t t-out="doc.date_start"/></td>
                            </tr>
                            <tr>
                                <th>Date de fin</th>
                                <td><t t-out="doc.date_end"/></td>
                            </tr>
                            <tr>
                                <th>Durée commandée</th>
                                <td><t t-out="dict(doc._fields['duration'].selection).get(doc.duration, '-')"/></td>
                            </tr>
                            <tr>
                                <th>Jours avant expiration</th>
                                <td><t t-out="doc.days_to_expiry"/></td>
                            </tr>
                        </table>

                        <!-- Facturation -->
                        <h4 class="mt-4">Facturation</h4>
                        <table class="table table-sm">
                            <tr>
                                <th style="width: 30%;">Montant de maintenance</th>
                                <td>
                                    <span t-out="doc.maintenance_amount"/>
                                    <span t-out="doc.currency_id.symbol or '€'"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Niveau de facturation</th>
                                <td><t t-out="doc.billing_level or '-'"/> %</td>
                            </tr>
                            <tr>
                                <th>Cadences</th>
                                <td>
                                    <t t-out="', '.join(doc.billing_frequency_ids.mapped('name')) or '-'"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Facturation modules</th>
                                <td>
                                    <t t-out="', '.join(doc.module_billing_ids.mapped('name')) or '-'"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Révision Syntec</th>
                                <td>
                                    <t t-out="dict(doc._fields['syntec_revision'].selection).get(doc.syntec_revision, '-')"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Montants annuels -->
                        <h4 class="mt-4">Montants annuels</h4>
                        <table class="table table-sm table-striped" t-if="doc.line_ids">
                            <thead>
                                <tr>
                                    <th>Année</th>
                                    <th class="text-end">Montant</th>
                                    <th class="text-center">Facturée</th>
                                    <th>Facture</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids.sorted(key=lambda l: l.year)" t-as="line">
                                    <td><t t-out="line.year"/></td>
                                    <td class="text-end">
                                        <span t-out="line.amount"/>
                                        <span t-out="doc.currency_id.symbol or '€'"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-if="line.is_invoiced" style="color: green;">✓</span>
                                        <span t-if="not line.is_invoiced" style="color: #999;">—</span>
                                    </td>
                                    <td>
                                        <t t-out="', '.join(line.invoice_ids.mapped('display_name')) or '-'"/>
                                    </td>
                                </tr>
                                <tr style="border-top: 2px solid #333;">
                                    <th>Total contrat</th>
                                    <th class="text-end">
                                        <t t-out="doc.total_contract_value"/>
                                        <t t-out="doc.currency_id.symbol or '€'"/>
                                    </th>
                                    <td/>
                                    <td/>
                                </tr>
                            </tbody>
                        </table>
                        <p t-if="not doc.line_ids" class="text-muted">
                            Aucune ligne annuelle (utiliser « Générer les lignes annuelles »).
                        </p>

                        <!-- Renouvellement -->
                        <div t-if="doc.renewed_from_id or doc.renewed_to_ids" class="mt-4">
                            <h4>Renouvellement</h4>
                            <p t-if="doc.renewed_from_id">
                                Ce contrat est le renouvellement de
                                <strong t-out="doc.renewed_from_id.sequence_number"/>.
                            </p>
                            <p t-if="doc.renewed_to_ids">
                                Ce contrat a été renouvelé en :
                                <strong t-out="', '.join(doc.renewed_to_ids.mapped('sequence_number'))"/>.
                            </p>
                        </div>

                        <!-- Commentaire -->
                        <div t-if="doc.comment" class="mt-4">
                            <h4>Commentaire</h4>
                            <p style="white-space: pre-wrap;"><t t-out="doc.comment"/></p>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
